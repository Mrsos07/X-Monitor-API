# ============================================================
#  X-Monitor  — .env.example
#  انسخ هذا الملف باسم .env وعدّل القيم
#  ⚠️  غيّر جميع القيم السرية قبل النشر
# ============================================================

# مفتاح API للمصادقة (غيّره إلى قيمة سرية)
API_KEY=x-monitor-secret-key-change-me

# إعدادات الخادم
APP_HOST=0.0.0.0
APP_PORT=8000

# فترة الاستطلاع الافتراضية بالثواني (30 ثانية)
MONITOR_INTERVAL_SECONDS=30

# عدد أحدث التغريدات يُجلب كل مرة
MAX_POSTS_PER_FETCH=10

# تشغيل المتصفح بدون واجهة رسومية (true في الإنتاج)
BROWSER_HEADLESS=true

# مسار ملف الكوكيز
COOKIES_FILE=cookies.json

# Webhook: مهلة الاتصال
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_ATTEMPTS=3

# واجهة الإدارة — غيّر البيانات قبل النشر
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
SESSION_SECRET=change-me-to-a-random-secret-key
